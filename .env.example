# MongoDB Atlas connection string (see setup.md for free tier guide)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/weed-diary

# Simple password-based auth (no JWT, no sessions)
AUTH_PASSWORD=your-secret-password-here

# Cloudinary image hosting (see setup.md for free tier guide)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Google Maps Embed API (optional, falls back to plain link)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Server port
PORT=5000
